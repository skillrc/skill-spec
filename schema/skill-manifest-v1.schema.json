{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.opencode.dev/schema/skill-manifest-v1.schema.json",
  "title": "OpenCode Skill Manifest v1",
  "type": "object",
  "required": ["manifest_version", "skill"],
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "1.0"
    },
    "skill": {
      "type": "object",
      "required": [
        "name",
        "version",
        "description",
        "type",
        "category",
        "boundary",
        "maturity",
        "last_verified",
        "tags",
        "topics"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:[-+][A-Za-z0-9.-]+)?$"
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "type": {
          "type": "string",
          "enum": ["technique", "pattern", "reference", "discipline"]
        },
        "category": {
          "type": "string",
          "enum": [
            "engineering",
            "frontend",
            "backend",
            "devops",
            "testing",
            "security",
            "research",
            "writing",
            "workflow",
            "product",
            "general"
          ]
        },
        "boundary": {
          "type": "string",
          "minLength": 10
        },
        "maturity": {
          "type": "string",
          "enum": ["draft", "alpha", "beta", "stable", "deprecated"]
        },
        "last_verified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          }
        },
        "non_goals": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string" },
        "license": { "type": "string" },
        "homepage": { "type": "string" }
      }
    },
    "compat": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "min_opencode_version": { "type": "string" },
        "min_skillmine_version": { "type": "string" }
      }
    }
  }
}
